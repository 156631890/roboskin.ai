{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "www.roboskin.ai"
        }
      ],
      "destination": "https://roboskin.ai",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.roboskin.ai"
        }
      ],
      "destination": "https://roboskin.ai/:path*",
      "permanent": true
    }
  ]
}
